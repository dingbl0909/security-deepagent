# 国内网络 Docker Hub 超时时使用（DaoCloud 公共镜像加速）
# 用法：cp .env.cn.example .env  &&  docker compose pull  &&  docker compose up -d
#
# 说明：官方 library 镜像需加 library/ 前缀；etcd 走 quay.io 一般可直连

COMPOSE_PROJECT_NAME=security-deepagent

POSTGRES_USER=security_agent
POSTGRES_PASSWORD=change_me
POSTGRES_DB=security_agent

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

POSTGRES_PORT=5432
REDIS_PORT=6379
MILVUS_GRPC_PORT=19530
MILVUS_METRICS_PORT=9091
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── 镜像（DaoCloud 前缀）──
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.16
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2024-05-28T17-19-04Z
MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.4.15
